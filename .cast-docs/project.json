{
  "version": 1,
  "name": "cast-a-doc",
  "displayName": "cast-a-doc",
  "description": "Component Assembly Styled Templates: render structured JSON engineering documents to self-contained HTML artifacts.",
  "defaultLocale": "en",
  "defaultDocumentType": "engineering-spec",
  "defaultScenario": "none",
  "owner": "CAST-Docs",
  "audience": [
    "engineering",
    "coding agents",
    "documentation maintainers"
  ],
  "output": {
    "defaultDir": "docs/cast-docs",
    "localDir": ".cast-docs/out",
    "filenamePattern": "{date}-{slug}.html"
  },
  "brand": {
    "logo": {
      "src": "assets/cast-docs-logo.png",
      "alt": "CAST Docs logo"
    }
  },
  "displayOwner": "CAST-Docs"
}
