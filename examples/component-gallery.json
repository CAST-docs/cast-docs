    {
      "id": "interactive-controls",
      "title": {
        "en": "Interactive Controls",
        "zh-CN": "交互控件"
      },
      "blocks": [
        {
          "type": "toggle-view",
          "defaultView": "overview",
          "views": [
            {
              "id": "overview",
              "label": {
                "en": "Overview",
                "zh-CN": "概览"
              },
              "blocks": [
                {
                  "type": "paragraph",
                  "text": {
                    "en": "This built-in button switches the visible view without custom inline JavaScript.",
                    "zh-CN": "这个内置按钮无需自定义 inline JavaScript，就能切换可见视图。"
                  }
                },
                {
                  "type": "list",
                  "items": [
                    {
                      "en": "Renderer owns the behavior.",
                      "zh-CN": "行为由渲染器托管。"
                    },
                    {
                      "en": "JSON owns the view content.",
                      "zh-CN": "JSON 承载视图内容。"
                    }
                  ]
                }
              ]
            },
            {
              "id": "json",
              "label": {
                "en": "JSON",
                "zh-CN": "JSON"
              },
              "blocks": [
                {
                  "type": "code",
                  "language": "json",
                  "code": "{\n  \"type\": \"toggle-view\",\n  \"defaultView\": \"overview\",\n  \"views\": [\"overview\", \"json\"]\n}"
                }
              ]
            }
          ]
