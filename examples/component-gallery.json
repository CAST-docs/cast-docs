                "text": {
                  "en": "  \"title\": \"Component gallery\",",
                  "zh-CN": "  \"title\": \"组件大全\","
                }
              },
              {
                "kind": "context",
                "text": {
                  "en": "  \"language\": \"en\"",
                  "zh-CN": "  \"language\": \"en\""
                }
              },
              {
                "kind": "context",
                "text": {
                  "en": "}",
                  "zh-CN": "}"
                }
              }
            ]
          },
          "right": {
            "label": {
              "en": "After",
              "zh-CN": "之后"
            },
            "language": "json",
            "lines": [
              {
                "kind": "context",
                "text": {
                  "en": "{",
                  "zh-CN": "{"
                }
              },
              {
                "kind": "add",
                "highlight": true,
                "text": {
                  "en": "  \"title\": { \"en\": \"Component gallery\", \"zh-CN\": \"组件大全\" },",
                  "zh-CN": "  \"title\": { \"en\": \"Component gallery\", \"zh-CN\": \"组件大全\" },"
                }
              },
              {
                "kind": "add",
                "text": {
                  "en": "  \"locales\": [\"en\", \"zh-CN\"]",
                  "zh-CN": "  \"locales\": [\"en\", \"zh-CN\"]"
                }
              },
              {
                "kind": "context",
                "text": {
                  "en": "}",
                  "zh-CN": "}"
                }
              }
            ]
          }
        }
      ]
    },
