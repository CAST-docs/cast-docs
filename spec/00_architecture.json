    {
      "id": "agent-readable-contract",
      "title": {
        "en": "Agent-Readable Contract",
        "zh-CN": "Agent 可读契约"
      },
      "blocks": [
        {
          "type": "paragraph",
          "text": {
            "en": "cast-a-doc treats JSON as the primary authoring surface and HTML as a generated artifact. Coding agents can inspect metadata, manifest, section ids, block types, and localized fields without parsing layout CSS, visual decoration, or browser-only state.",
            "zh-CN": "cast-a-doc 把 JSON 作为主要写作界面，把 HTML 作为生成产物。coding agent 可以直接检查 metadata、manifest、section id、block type 和多语言字段，而不需要解析布局 CSS、视觉装饰或浏览器状态。"
          }
        },
        {
          "type": "diagram",
          "kind": "sequence",
          "title": {
            "en": "Agent Read Path",
            "zh-CN": "Agent 读取路径"
          },
          "downloadName": "agent-read-path",
          "source": {
            "format": "structured-sequence",
            "steps": [
              {
                "from": {
                  "en": "Agent",
                  "zh-CN": "Agent"
                },
                "to": {
                  "en": "Repository",
                  "zh-CN": "仓库"
                },
                "label": {
                  "en": "Read small JSON source",
                  "zh-CN": "读取小型 JSON 源"
                }
              },
              {
                "from": {
                  "en": "Repository",
                  "zh-CN": "仓库"
                },
                "to": {
                  "en": "Schema",
                  "zh-CN": "Schema"
                },
                "label": {
                  "en": "Validate shape and allowed blocks",
                  "zh-CN": "校验结构和允许的 blocks"
                }
              },
              {
                "from": {
                  "en": "Agent",
                  "zh-CN": "Agent"
                },
                "to": {
                  "en": "Renderer",
                  "zh-CN": "渲染器"
                },
                "label": {
                  "en": "Render after source edits",
                  "zh-CN": "源文件修改后渲染"
                }
              },
              {
                "from": {
                  "en": "Renderer",
                  "zh-CN": "渲染器"
                },
                "to": {
                  "en": "HTML",
                  "zh-CN": "HTML"
                },
                "label": {
                  "en": "Emit reader artifact",
                  "zh-CN": "输出读者产物"
                }
              }
            ]
          }
        },
        {
          "type": "table",
          "tableType": "data",
          "headers": [
            {
              "en": "Mechanism",
              "zh-CN": "机制"
            },
            {
              "en": "Agent benefit",
              "zh-CN": "Agent 收益"
            },
            {
              "en": "Design rule",
              "zh-CN": "设计规则"
            }
          ],
          "rows": [
            [
              {
                "en": "Typed blocks",
                "zh-CN": "类型化 blocks"
              },
              {
                "en": "Agents can jump to a known block contract instead of inferring prose intent.",
                "zh-CN": "agent 可跳到已知 block 契约，而不是从散文里推断意图。"
              },
              {
                "en": "Every block type is registered in config/components.json and validated by schema/runtime checks.",
                "zh-CN": "每个 block type 都在 config/components.json 注册，并由 schema/runtime 校验。"
              }
            ],
            [
              {
                "en": "Manifest section order",
                "zh-CN": "manifest 章节顺序"
              },
              {
                "en": "Agents can diff declared structure against actual sections before reading details.",
                "zh-CN": "agent 可先对比声明结构和实际 sections，再进入细节。"
              },
              {
                "en": "manifest.sections must match sections[].id exactly.",
                "zh-CN": "manifest.sections 必须和 sections[].id 完全一致。"
              }
            ],
            [
              {
                "en": "Localized field objects",
                "zh-CN": "多语言字段对象"
              },
              {
                "en": "Agents can update one semantic field in both languages without duplicating layout.",
                "zh-CN": "agent 可在同一个语义字段里更新双语内容，不复制布局。"
              },
              {
                "en": "Reader-facing text is string or {en, zh-CN}; renderer handles visibility.",
                "zh-CN": "读者可见文本为字符串或 {en, zh-CN}；渲染器负责可见性。"
              }
            ],
            [
              {
                "en": "Source-first workflow",
                "zh-CN": "源文件优先工作流"
              },
              {
                "en": "Agents edit compact JSON, then regenerate HTML; large generated files are not the thinking surface.",
                "zh-CN": "agent 编辑紧凑 JSON，再重新生成 HTML；大型生成文件不是思考界面。"
              },
              {
                "en": "Checked-in HTML exists for Pages and review, but JSON remains the authoring source.",
                "zh-CN": "HTML 入库用于 Pages 和审阅，但 JSON 仍是写作源。"
              }
            ]
          ]
        }
      ]
