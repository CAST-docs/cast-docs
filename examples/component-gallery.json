      "title": {
        "en": "Rich Text Marks",
        "zh-CN": "富文本标记"
      },
      "blocks": [
        {
          "type": "paragraph",
          "text": {
            "en": [
              {
                "text": "Inline marks include "
              },
              {
                "text": "strong",
                "marks": [
                  "strong"
                ]
              },
              {
                "text": ", "
              },
              {
                "text": "italic",
                "marks": [
                  "em"
                ]
              },
              {
                "text": ", "
              },
              {
                "text": "code",
                "marks": [
                  "code"
                ]
              },
              {
                "text": ", "
              },
              {
