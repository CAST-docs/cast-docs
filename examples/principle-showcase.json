      "blocks": [
        {
          "type": "summary",
          "items": [
            {
              "label": {
                "en": "Purpose",
                "zh-CN": "目的"
              },
              "body": {
                "en": "Keep generated HTML stable, reusable, and easy to validate.",
                "zh-CN": "保持生成的 HTML 稳定、可复用且易于校验。"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "context",
      "title": {
        "en": "Context",
        "zh-CN": "背景"
      },
      "blocks": [
        {
          "type": "paragraph",
          "text": {
            "en": [
              {
                "text": "The renderer produces "
              },
              {
                "text": "deterministic",
                "marks": [
                  {
                    "type": "term",
                    "definition": "same input yields byte-identical output"
                  }
                ]
              },
              {
                "text": " documents "
              },
              {
                "text": "without",
                "marks": [
                  "em"
                ]
              },
              {
                "text": " copying large templates into model context."
              }
            ],
            "zh-CN": [
              {
                "text": "渲染器会生成 "
              },
              {
                "text": "确定性的",
                "marks": [
                  {
                    "type": "term",
                    "definition": "same input yields byte-identical output"
                  }
                ]
              },
              {
                "text": " 文档，"
              },
              {
                "text": "无需",
                "marks": [
                  "em"
                ]
              },
              {
                "text": " 将大型模板复制进模型上下文。"
              }
            ]
          }
        }
      ]
    },
    {
