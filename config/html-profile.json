{
  "version": 1,
  "doctypeRequired": true,
  "allowedSchemes": {
    "userContent": ["anchor", "relative", "http", "https"],
    "rendererOwned": ["anchor", "relative", "http", "https", "openinfinder"]
  },
  "allowedTags": {
    "content": [
      "article",
      "header",
      "nav",
      "main",
      "div",
      "span",
      "section",
      "footer",
      "h1",
      "h2",
      "h3",
      "p",
      "a",
      "strong",
      "em",
      "code",
      "del",
      "u",
      "mark",
      "pre",
      "ul",
      "ol",
      "li",
      "table",
      "thead",
      "tbody",
      "tr",
      "th",
      "td",
      "dl",
      "dt",
      "dd",
      "aside",
      "details",
      "summary",
      "figure",
      "figcaption",
      "img",
      "svg",
      "g",
      "path",
      "rect",
      "circle",
      "line",
      "polyline",
      "polygon",
      "text",
      "defs",
      "marker"
    ],
    "rendererOwned": ["html", "head", "meta", "title", "style", "body", "script", "button"]
  },
  "globalAttributes": [
    "id",
    "class",
    "title",
    "role",
    "aria-label",
    "aria-hidden",
    "aria-modal",
    "data-slot",
    "data-component",
    "data-interaction",
    "data-download-name",
    "data-i18n-key",
    "data-copy-target",
    "data-language",
    "data-view-group",
    "data-view-target",
    "data-view-panel",
    "data-view-active",
    "data-locale",
    "data-locale-active",
    "data-locale-target",
    "data-renderer-owned",
    "data-mark"
  ],
  "tagAttributes": {
    "html": ["lang"],
    "meta": ["charset", "name", "content"],
    "a": ["href", "target", "rel"],
    "img": ["src", "alt", "loading", "width", "height"],
    "code": ["data-language"],
    "pre": ["data-language"],
    "table": ["data-table-type"],
    "details": ["open"],
    "th": ["scope"],
    "td": ["colspan", "rowspan"],
    "button": ["type", "disabled", "aria-pressed"],
    "script": ["type", "id", "data-interaction"],
    "svg": ["xmlns", "viewBox", "width", "height", "aria-labelledby", "role"],
    "g": ["transform"],
    "path": ["d", "fill", "stroke", "stroke-width", "stroke-linecap", "stroke-linejoin", "marker-end"],
    "rect": ["x", "y", "width", "height", "rx", "ry", "fill", "stroke", "stroke-width"],
    "circle": ["cx", "cy", "r", "fill", "stroke", "stroke-width"],
    "line": ["x1", "y1", "x2", "y2", "stroke", "stroke-width", "stroke-linecap", "stroke-dasharray", "marker-end"],
    "polyline": ["points", "fill", "stroke", "stroke-width", "stroke-linecap", "stroke-linejoin", "marker-end"],
    "polygon": ["points", "fill", "stroke", "stroke-width"],
    "text": ["x", "y", "fill", "font-size", "text-anchor", "dominant-baseline"],
    "marker": ["id", "viewBox", "refX", "refY", "markerWidth", "markerHeight", "orient"]
  },
  "allowedClasses": [
    "doc",
    "sidebar",
    "topbar",
    "topbar-title",
    "topbar-links",
    "topbar-link",
    "topbar-spacer",
    "topbar-pill",
    "locale-switcher",
    "locale-button",
    "doc-header",
    "doc-kicker",
    "doc-summary",
    "doc-meta",
    "nav-title",
    "toc",
    "doc-section",
    "section-empty",
    "callout",
    "callout-info",
    "callout-warning",
    "callout-danger",
    "callout-success",
    "data-table",
    "risk-table",
    "decision-table",
    "status-pill",
    "details-block",
    "code-block",
    "code-shell",
    "code-header",
    "code-language",
    "code-status",
    "code-status-neutral",
    "code-status-ok",
    "code-status-error",
    "code-copy",
    "code-pre",
    "code-line",
    "code-line-number",
    "code-line-content",
    "code-scheme-json",
    "code-scheme-js",
    "code-scheme-ts",
    "code-scheme-shell",
    "code-scheme-python",
    "code-scheme-text",
    "code-token-key",
    "code-token-bool",
    "code-token-number",
    "code-token-flag",
    "diagram",
    "diagram-toolbar",
    "svg-figure",
    "lightbox",
    "lightbox-panel",
    "lightbox-body",
    "lightbox-toolbar",
    "lightbox-close",
    "diff-block",
    "diff-side",
    "diff-code",
    "diff-line",
    "diff-line-number",
    "diff-line-marker",
    "diff-line-content",
    "line-add",
    "line-remove",
    "line-warning",
    "line-context",
    "line-highlight",
    "media-grid",
    "media-frame",
    "media-kind",
    "columns",
    "column",
    "toggle-view",
    "toggle-toolbar",
    "toggle-button",
    "toggle-panel",
    "participants",
    "participant-card",
    "source-refs",
    "files",
    "action-card",
    "prompt-block",
    "values-grid",
    "value-card",
    "acceptance-criteria",
    "open-questions",
    "doc-footer"
  ],
  "forbiddenAttributes": ["onclick", "onload", "onerror", "onmouseover", "style"],
  "forbiddenTags": ["iframe", "object", "embed", "link", "video", "audio", "canvas", "form", "input", "textarea", "select"]
}
