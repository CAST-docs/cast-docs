      "blocks": [
        {
          "type": "values-grid",
          "items": [
            {
              "title": {
                "en": "Consistent output",
                "zh-CN": "一致输出"
              },
              "body": {
                "en": [
                  {
                    "text": "Use "
                  },
                  {
                    "text": "one shared shell",
                    "marks": [
                      "mark"
                    ]
                  },
                  {
                    "text": " and semantic classes."
                  }
                ],
                "zh-CN": [
                  {
                    "text": "使用 "
                  },
                  {
                    "text": "一个共享 shell",
                    "marks": [
                      "mark"
                    ]
                  },
                  {
                    "text": " 和语义化类名。"
                  }
                ]
              }
            },
            {
              "title": {
                "en": "On-demand composition",
                "zh-CN": "按需组合"
              },
              "body": {
                "en": "Render only selected components.",
                "zh-CN": "只渲染被选择的组件。"
              }
            },
            {
              "title": {
                "en": "Scenario skeletons",
                "zh-CN": "场景骨架"
              },
              "body": {
                "en": "Use configured section order.",
                "zh-CN": "使用已配置的章节顺序。"
              }
            },
            {
              "title": {
                "en": "Reuse first",
                "zh-CN": "复用优先"
              },
              "body": {
                "en": "Prefer existing components and schema fragments.",
                "zh-CN": "优先使用已有组件和 schema 片段。"
              }
            }
          ]
        }
      ]
