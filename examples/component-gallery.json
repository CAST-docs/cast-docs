{
  "metadata": {
    "title": {
      "en": "Component gallery",
      "zh-CN": "组件大全"
    },
    "language": "en",
    "locales": [
      "en",
      "zh-CN"
    ],
    "status": "draft",
    "owner": "CAST-docs",
    "audience": [
      "maintainers",
      "template authors"
    ],
    "updatedAt": "2026-05-27",
    "description": {
      "en": "A compact gallery of CAST Docs blocks, inline marks, tables, diff views, diagrams, and document cards.",
      "zh-CN": "CAST Docs blocks、富文本标记、表格、diff 视图、图表和文档卡片的紧凑组件大全。"
    },
    "shellLinks": [
      {
        "label": {
          "en": "CAST Docs",
          "zh-CN": "CAST Docs"
        },
        "href": "../index.html",
        "placement": "topbar"
      }
    ]
  },
  "manifest": {
    "documentType": "engineering-spec",
    "scenario": "none",
    "sections": [
      "plain-content",
      "rich-text",
      "lists-and-criteria",
      "tables",
      "blocks-view",
      "code-and-diff",
      "media-and-columns",
      "interactive-controls",
      "evidence-and-people",
      "diagrams"
    ],
    "components": {
      "required": [
        "summary-block",
        "metadata-block",
        "toc",
        "section",
        "paragraph"
      ],
      "optional": [
        "list",
        "callout",
        "table",
        "details-block",
        "code-block",
        "diagram",
        "diff-block",
        "media-grid",
        "columns",
        "toggle-view",
        "participants",
        "source-refs",
        "files",
        "action-card",
        "values-grid",
        "acceptance-criteria",
        "open-questions"
      ],
      "omitted": [
        "inline-svg-figure"
      ]
    }
  },
  "sections": [
    {
      "id": "plain-content",
      "title": {
        "en": "Plain Content",
        "zh-CN": "基础内容"
      },
      "blocks": [
        {
          "type": "summary",
          "items": [
            {
              "label": {
                "en": "Purpose",
                "zh-CN": "用途"
              },
              "body": {
                "en": "Use this page to inspect the visual language and regression-test every common block.",
                "zh-CN": "使用本页检查视觉语言，并回归测试所有常用 block。"
              }
            },
            {
              "label": {
                "en": "Order",
                "zh-CN": "顺序"
              },
              "body": {
                "en": "The gallery starts with simple prose and ends with interactive diagrams.",
                "zh-CN": "组件大全从简单 prose 开始，逐步到交互式图表。"
              }
            }
          ]
        },
        {
          "type": "paragraph",
          "text": {
            "en": "A paragraph is the smallest prose block. It should read comfortably, preserve links, and keep spacing stable around richer components.",
            "zh-CN": "段落是最小的 prose block。它应该易读，保留链接，并在复杂组件周围保持稳定间距。"
          }
        },
        {
          "type": "callout",
          "variant": "info",
          "title": {
            "en": "Info callout",
            "zh-CN": "信息提示"
          },
          "body": {
            "en": "Callouts highlight context without replacing the surrounding explanation.",
            "zh-CN": "Callout 用于强调上下文，但不替代周围说明。"
          }
        }
      ]
    },
    {
