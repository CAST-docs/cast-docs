  "sections": [
    {
      "id": "choose-an-install",
      "title": {
        "en": "Choose an install",
        "zh-CN": "选择安装方式"
      },
      "blocks": [
        {
          "type": "summary",
          "items": [
            {
              "label": {
                "en": "Default",
                "zh-CN": "默认"
              },
              "body": {
                "en": "Install the Codex skill with `gh skill install`.",
                "zh-CN": "使用 `gh skill install` 安装 Codex skill。"
              }
            },
            {
              "label": {
                "en": "Also supported",
                "zh-CN": "同时支持"
              },
              "body": {
                "en": "Claude Code, both-agent setup, user/project scope, version pinning, and local renderer smoke tests.",
                "zh-CN": "Claude Code、双 agent 安装、user/project scope、版本 pinning 和本地渲染器冒烟测试。"
              }
            },
            {
              "label": {
                "en": "Requirements",
                "zh-CN": "环境要求"
              },
              "body": {
                "en": "GitHub CLI with `gh skill install` support for skill installation; Python 3.9 or newer for rendering documents.",
                "zh-CN": "安装 skill 需要支持 `gh skill install` 的 GitHub CLI；渲染文档需要 Python 3.9 或更新版本。"
              }
            }
          ]
        },
        {
          "type": "callout",
          "variant": "info",
          "title": {
            "en": "What the installer does",
            "zh-CN": "安装脚本会做什么"
          },
          "body": {
            "en": "The compatibility installer delegates to `gh skill install` for the selected agent. It no longer clones or pulls repositories into agent skill directories and does not install Python packages.",
            "zh-CN": "兼容安装脚本会为选定 agent 委托执行 `gh skill install`。它不再把仓库 clone 或 pull 到 agent skill 目录，也不会安装 Python 包。"
          }
        }
      ]
    },
    {
      "id": "codex-skill",
      "title": {
        "en": "Codex skill",
        "zh-CN": "Codex skill"
      },
      "blocks": [
        {
          "type": "action",
          "title": {
            "en": "Install or update for Codex",
            "zh-CN": "安装或更新到 Codex"
          },
          "description": {
            "en": "Installs or updates cast-a-doc for Codex at user scope through GitHub CLI.",
            "zh-CN": "通过 GitHub CLI 以 user scope 为 Codex 安装或更新 cast-a-doc。"
          },
          "prompt": {
            "en": "gh skill install CAST-docs/cast-a-doc cast-a-doc --agent codex --scope user",
            "zh-CN": "gh skill install CAST-docs/cast-a-doc cast-a-doc --agent codex --scope user"
          }
        },
        {
          "type": "paragraph",
          "text": {
            "en": "Restart Codex if it was already running so the skill list can refresh.",
            "zh-CN": "如果 Codex 已经在运行，安装后重启一次，让 skill 列表刷新。"
          }
        }
      ]
    },
    {
      "id": "claude-code-skill",
      "title": {
        "en": "Claude Code skill",
        "zh-CN": "Claude Code skill"
      },
      "blocks": [
        {
          "type": "action",
          "title": {
            "en": "Install or update for Claude Code",
            "zh-CN": "安装或更新到 Claude Code"
          },
          "description": {
            "en": "Installs or updates cast-a-doc for Claude Code at user scope through GitHub CLI.",
            "zh-CN": "通过 GitHub CLI 以 user scope 为 Claude Code 安装或更新 cast-a-doc。"
          },
          "prompt": {
            "en": "gh skill install CAST-docs/cast-a-doc cast-a-doc --agent claude-code --scope user",
            "zh-CN": "gh skill install CAST-docs/cast-a-doc cast-a-doc --agent claude-code --scope user"
          }
        },
        {
          "type": "paragraph",
          "text": {
            "en": "Restart Claude Code after installation if it was already open.",
            "zh-CN": "如果 Claude Code 已经打开，安装后重启一次。"
          }
        }
      ]
    },
    {
      "id": "both-agent-skills",
      "title": {
        "en": "Both agent skills",
        "zh-CN": "双 agent 安装"
      },
      "blocks": [
        {
          "type": "action",
          "title": {
            "en": "Install for Codex and Claude Code",
            "zh-CN": "同时安装到 Codex 和 Claude Code"
          },
          "description": {
            "en": "Runs `gh skill install` for both Codex and Claude Code. Use this when you switch between agents and want one shared document workflow.",
            "zh-CN": "为 Codex 和 Claude Code 分别执行 `gh skill install`。适合在不同 agent 间切换、但希望使用同一套文档工作流的场景。"
          },
          "prompt": {
            "en": "curl -fsSL https://cast-docs.github.io/cast-a-doc/install.sh | bash -s -- --both",
            "zh-CN": "curl -fsSL https://cast-docs.github.io/cast-a-doc/install.sh | bash -s -- --both"
          }
        }
      ]
    },
    {
      "id": "local-renderer",
      "title": {
        "en": "Local renderer",
        "zh-CN": "本地渲染器"
      },
      "blocks": [
        {
          "type": "paragraph",
          "text": {
            "en": "Use the local renderer when you want to develop cast-a-doc itself, render examples, or validate generated document JSON outside an agent.",
            "zh-CN": "当你要开发 cast-a-doc 本身、渲染示例，或在 agent 之外校验生成的文档 JSON 时，使用本地渲染器。"
          }
        },
        {
          "type": "code",
          "language": "sh",
          "code": "git clone https://github.com/CAST-docs/cast-a-doc.git /tmp/cast-a-doc\ncd /tmp/cast-a-doc\nscripts/render_example.sh examples/problem-investigation.json out.html"
        },
        {
          "type": "paragraph",
          "text": {
            "en": "The smoke test validates the source JSON, renders HTML, and validates the rendered HTML profile.",
            "zh-CN": "冒烟测试会校验源 JSON、渲染 HTML，并校验渲染后的 HTML profile。"
          }
        }
      ]
    },
    {
      "id": "project-profile",
      "title": {
        "en": "Project profile",
        "zh-CN": "项目级配置"
      },
      "blocks": [
        {
          "type": "paragraph",
          "text": {
            "en": "After installation, a target repository can add .cast-docs/ when it wants cast-a-doc to remember team-specific defaults.",
            "zh-CN": "安装后，如果目标仓库希望 cast-a-doc 记住团队级默认设置，可以添加 .cast-docs/。"
          }
        },
        {
          "type": "code",
          "language": "text",
          "code": ".cast-docs/\n  project.json\n  preferences.json\n  i18n.json\n  glossary.json\n  writing-style.md\n  templates/\n  examples/\n  assets/\n  out/"
        },
        {
          "type": "list",
          "items": [
            {
              "en": "Use project.json for repository metadata, default locale, brand logo, and output directories.",
              "zh-CN": "用 project.json 保存仓库元信息、默认语言、品牌 logo 和输出目录。"
            },
            {
              "en": "Use templates/ and examples/ for reusable team document shapes.",
              "zh-CN": "用 templates/ 和 examples/ 保存可复用的团队文档结构。"
            },
            {
              "en": "Use assets/ for repository logos, icons, screenshots, and reusable media.",
              "zh-CN": "用 assets/ 保存仓库 logo、图标、截图和可复用媒体。"
            },
            {
              "en": "Use docs/cast-docs/ for shareable output and .cast-docs/out/ for local drafts.",
              "zh-CN": "共享产物放到 docs/cast-docs/，本地草稿放到 .cast-docs/out/。"
            }
          ]
        },
        {
          "type": "callout",
          "variant": "warning",
          "title": {
            "en": "Do not create hidden memory",
            "zh-CN": "不要创建隐藏记忆"
          },
          "body": {
            "en": "Only create or update .cast-docs/ when the user asks the agent to remember repository-specific settings. The current user request still overrides profile defaults.",
            "zh-CN": "只有在用户要求 agent 记住仓库级设置时，才创建或更新 .cast-docs/。当前用户诉求仍然优先于 profile 默认值。"
          }
        }
      ]
    },
    {
      "id": "customization",
      "title": {
        "en": "Customization",
        "zh-CN": "自定义安装"
      },
      "blocks": [
        {
          "type": "paragraph",
          "text": {
            "en": "The compatibility installer accepts flags and environment variables for agent selection, user/project scope, version pinning, and GitHub repository overrides.",
            "zh-CN": "兼容安装脚本支持参数和环境变量，用于选择 agent、user/project scope、版本 pinning 和 GitHub 仓库覆盖。"
          }
        },
        {
          "type": "list",
          "items": [
            {
              "en": [
                {
                  "text": "--codex",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": ", "
                },
                {
                  "text": "--claude",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": ", or "
                },
                {
                  "text": "--both",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " chooses the target agent."
                }
              ],
              "zh-CN": [
                {
                  "text": "--codex",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": "、"
                },
                {
                  "text": "--claude",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " 或 "
                },
                {
                  "text": "--both",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " 用于选择目标 agent。"
                }
              ]
            },
            {
              "en": [
                {
                  "text": "CAST_A_DOC_AGENT=codex|claude-code|both",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " sets the same choice through the environment."
                }
              ],
              "zh-CN": [
                {
                  "text": "CAST_A_DOC_AGENT=codex|claude-code|both",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " 可以通过环境变量设置同样的选择。"
                }
              ]
            },
            {
              "en": [
                {
                  "text": "CAST_A_DOC_SCOPE=user|project",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " chooses the install scope."
                }
              ],
              "zh-CN": [
                {
                  "text": "CAST_A_DOC_SCOPE=user|project",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " 用于选择安装 scope。"
                }
              ]
            },
            {
              "en": [
                {
                  "text": "CAST_A_DOC_VERSION",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " pins cast-a-doc to a tag or commit SHA."
                }
              ],
              "zh-CN": [
                {
                  "text": "CAST_A_DOC_VERSION",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " 可把 cast-a-doc 固定到 tag 或 commit SHA。"
                }
              ]
            },
            {
              "en": [
                {
                  "text": "CAST_A_DOC_REPOSITORY",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " points the installer at a GitHub fork or mirror in "
                },
                {
                  "text": "OWNER/REPO",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " format."
                }
              ],
              "zh-CN": [
                {
                  "text": "CAST_A_DOC_REPOSITORY",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " 可把安装源指向 "
                },
                {
                  "text": "OWNER/REPO",
                  "marks": [
                    "code"
                  ]
                },
                {
                  "text": " 格式的 GitHub fork 或镜像。"
                }
              ]
            }
          ]
        },
        {
          "type": "code",
          "language": "sh",
          "code": "CAST_A_DOC_VERSION=v0.1.0 \\\nCAST_A_DOC_SCOPE=user \\\ncurl -fsSL https://cast-docs.github.io/cast-a-doc/install.sh | bash"
        }
      ]
    },
    {
      "id": "troubleshooting",
      "title": {
        "en": "Troubleshooting",
        "zh-CN": "排查问题"
      },
      "blocks": [
        {
          "type": "list",
          "items": [
            {
              "en": "If `gh skill install` is unavailable, upgrade GitHub CLI before running the installer.",
              "zh-CN": "如果缺少 `gh skill install`，请先升级 GitHub CLI 再运行安装脚本。"
            },
            {
              "en": "Use `gh skill preview CAST-docs/cast-a-doc cast-a-doc` to inspect the skill before installing.",
              "zh-CN": "安装前可用 `gh skill preview CAST-docs/cast-a-doc cast-a-doc` 审阅 skill 内容。"
            },
            {
              "en": "Use `gh skill install ... --pin <version>` when you need a known tag or commit.",
              "zh-CN": "需要固定到已知 tag 或 commit 时，使用 `gh skill install ... --pin <version>`。"
            },
            {
              "en": "If an agent does not detect the skill after installation, restart the agent application.",
              "zh-CN": "如果安装后 agent 没有识别 skill，请重启对应 agent 应用。"
            }
          ]
        },
        {
          "type": "callout",
          "variant": "warning",
          "title": {
            "en": "Review before piping shell scripts",
            "zh-CN": "管道执行前先审阅脚本"
          },
          "body": {
            "en": [
              {
                "text": "For stricter environments, download "
              },
              {
                "text": "install.sh",
                "marks": [
                  {
                    "type": "link",
                    "href": "install.sh"
                  }
                ]
              },
              {
                "text": " first, inspect it, then run it locally with bash "
              },
              {
                "text": "install.sh",
                "marks": [
                  {
                    "type": "link",
                    "href": "install.sh"
                  }
                ]
              },
              {
                "text": "."
              }
            ],
            "zh-CN": [
              {
                "text": "在更严格的环境中，可以先下载 "
              },
              {
                "text": "install.sh",
                "marks": [
                  {
                    "type": "link",
                    "href": "install.sh"
                  }
                ]
              },
              {
                "text": " 并审阅，再用 bash "
              },
              {
                "text": "install.sh",
                "marks": [
                  {
                    "type": "link",
                    "href": "install.sh"
                  }
                ]
              },
              {
                "text": " 在本地执行。"
              }
            ]
          }
        },
        {
          "type": "code",
          "language": "sh",
          "code": "curl -fsSLO https://cast-docs.github.io/cast-a-doc/install.sh\nless install.sh\nbash install.sh --help"
        }
      ]
    },
